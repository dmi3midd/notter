{
	"info": {
		"name": "Notter API",
		"description": "Notter API collection with automatic token management.\n\n**How it works:**\n1. Run Login or Registration request\n2. accessToken is automatically saved to collection variable\n3. All protected requests (Notes, Boards) use it automatically",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080"
		},
		{
			"key": "accessToken",
			"value": ""
		}
	],
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{accessToken}}",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Auth",
			"item": [
				{
					"name": "Registration",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    if (jsonData.accessToken) {",
									"        pm.collectionVariables.set('accessToken', jsonData.accessToken);",
									"        console.log('✅ accessToken saved');",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"testuser\",\n    \"email\": \"test@example.com\",\n    \"password\": \"password1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/users/registration",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "registration"]
						}
					}
				},
				{
					"name": "Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    if (jsonData.accessToken) {",
									"        pm.collectionVariables.set('accessToken', jsonData.accessToken);",
									"        console.log('✅ accessToken saved');",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"test1@example.com\",\n    \"password\": \"password1234\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/users/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "login"]
						}
					}
				},
				{
					"name": "Logout",
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/users/logout",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "logout"]
						}
					}
				},
				{
					"name": "Refresh Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    const jsonData = pm.response.json();",
									"    if (jsonData.accessToken) {",
									"        pm.collectionVariables.set('accessToken', jsonData.accessToken);",
									"        console.log('✅ accessToken refreshed');",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/users/refresh",
							"host": ["{{baseUrl}}"],
							"path": ["api", "users", "refresh"]
						}
					}
				}
			]
		},
		{
			"name": "Notes",
			"item": [
				{
					"name": "Get Standalone Notes",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/notes/standalone",
							"host": ["{{baseUrl}}"],
							"path": ["api", "notes", "standalone"]
						}
					}
				},
				{
					"name": "Get Board Notes",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/notes/board/:boardId",
							"host": ["{{baseUrl}}"],
							"path": ["api", "notes", "board", ":boardId"],
							"variable": [
								{
									"key": "boardId",
									"value": ""
								}
							]
						}
					}
				},
				{
					"name": "Get Note by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/notes/:noteId",
							"host": ["{{baseUrl}}"],
							"path": ["api", "notes", ":noteId"],
							"variable": [
								{
									"key": "noteId",
									"value": ""
								}
							]
						}
					}
				},
				{
					"name": "Create Standalone Note",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"My Note\",\n    \"content\": \"Note content here\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/notes/",
							"host": ["{{baseUrl}}"],
							"path": ["api", "notes", ""]
						}
					}
				},
				{
					"name": "Create Board Note",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Board Note\",\n    \"content\": \"Note content here\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/notes/:boardId",
							"host": ["{{baseUrl}}"],
							"path": ["api", "notes", ":boardId"],
							"variable": [
								{
									"key": "boardId",
									"value": ""
								}
							]
						}
					}
				},
				{
					"name": "Update Note",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Updated Title\",\n    \"content\": \"Updated content\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/notes/:noteId",
							"host": ["{{baseUrl}}"],
							"path": ["api", "notes", ":noteId"],
							"variable": [
								{
									"key": "noteId",
									"value": ""
								}
							]
						}
					}
				},
				{
					"name": "Delete Note",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/notes/:noteId",
							"host": ["{{baseUrl}}"],
							"path": ["api", "notes", ":noteId"],
							"variable": [
								{
									"key": "noteId",
									"value": ""
								}
							]
						}
					}
				}
			]
		},
		{
			"name": "Boards",
			"item": [
				{
					"name": "Get Boards",
					"request": {
						"method": "GET",
