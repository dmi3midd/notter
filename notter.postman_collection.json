				},
				{
					"name": "Delete Board",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/boards/:boardId",
							"host": ["{{baseUrl}}"],
							"path": ["api", "boards", ":boardId"],
							"variable": [
								{
									"key": "boardId",
									"value": ""
								}
							]
						}
					}
				}
			]
		}
	]
}
