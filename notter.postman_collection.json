							"host": ["{{baseUrl}}"],
							"path": ["api", "boards", ""]
						}
					}
				},
				{
					"name": "Create Board",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"My Board\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/boards/",
							"host": ["{{baseUrl}}"],
							"path": ["api", "boards", ""]
						}
					}
				},
				{
					"name": "Update Board",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"title\": \"Updated Board Title\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/boards/:boardId",
							"host": ["{{baseUrl}}"],
							"path": ["api", "boards", ":boardId"],
